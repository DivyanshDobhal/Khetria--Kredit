# MongoDB Atlas example connection
# 1) Create a MongoDB Atlas cluster and a database user
# 2) Whitelist your IP (or use 0.0.0.0/0 for dev)
# 3) Replace <username> and <password> and paste into your project's .env

DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/kshetraKredit?retryWrites=true&w=majority"
JWT_SECRET="change_this_to_a_strong_random_value"
JWT_EXPIRES_IN="7d"
PORT=5000
NODE_ENV=development

# Frontend config
VITE_API_BASE_URL=https://your-backend-url.example.com/api
